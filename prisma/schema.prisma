generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Conversation {
  id              String    @id @default(uuid())
  providerContact String    @unique // e.g., phone number
  state           State     @default(NEW)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  messages        Message[]
}

enum State {
  NEW
  CLASSIFYING
  ANSWERING
  WAITING_USER
  HANDOFF
  CLOSED
}

model Message {
  id                String       @id @default(uuid())
  conversationId    String
  conversation      Conversation @relation(fields: [conversationId], references: [id])
  providerMessageId String       @unique
  direction         Direction
  content           String
  payload           Json?        // store full provider payload
  createdAt         DateTime     @default(now())

  @@index([conversationId])
}

enum Direction {
  INBOUND
  OUTBOUND
}
