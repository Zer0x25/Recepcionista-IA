generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Conversation {
  id              String            @id @default(uuid())
  providerContact String            @unique // e.g., phone number
  state           State             @default(NEW)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  messages        Message[]
  transitions     StateTransition[]
  jobs            Job[]

  // Index for future metrics and filtering by conversation state
  @@index([state])
}

enum State {
  NEW
  CLASSIFYING
  ANSWERING
  WAITING_USER
  HANDOFF
  CLOSED
}

model StateTransition {
  id             String   @id @default(uuid())
  conversationId String
  fromState      State
  toState        State
  triggeredBy    String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id])
}

model Message {
  id                String       @id @default(uuid())
  conversationId    String
  conversation      Conversation @relation(fields: [conversationId], references: [id])
  providerMessageId String       @unique
  direction         Direction
  content           String
  payload           Json? // store full provider payload
  createdAt         DateTime     @default(now())

  @@index([conversationId])
}

enum Direction {
  INBOUND
  OUTBOUND
}

// ---------------------------------------------------------------------------
// Outbox / Job model (ADR-006)
// ---------------------------------------------------------------------------

enum JobStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

enum JobType {
  AI_REPLY_REQUESTED
}

model Job {
  id             String    @id @default(uuid())
  type           JobType
  conversationId String
  payload        Json
  status         JobStatus @default(PENDING)
  attempts       Int       @default(0)
  maxAttempts    Int       @default(5)
  nextRunAt      DateTime  @default(now())
  lockedAt       DateTime?
  lockedBy       String?
  lastError      String?
  idempotencyKey String    @unique
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  // Worker claim index
  @@index([status, nextRunAt])
  // Conversation history index
  @@index([conversationId, createdAt])
  // Lock cleanup index
  @@index([lockedAt])
  // Idempotency / deduplication lookup
  @@index([type, conversationId])
}
